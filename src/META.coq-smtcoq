package "smtcoq" (
  directory = "."
  version = "dev+9.0"
  description = "A Coq plugin that checks proof witnesses coming from external SAT and SMT solvers"
  requires = "rocq-runtime.plugins.ltac num rocq-runtime.plugins.micromega"
  archive(byte) = "smtcoq_plugin.cma"
  archive(native) = "smtcoq_plugin.cmxa"
  plugin(byte) = "smtcoq_plugin.cma"
  plugin(native) = "smtcoq_plugin.cmxs"
)
directory = "."
